                }

                currentFetchedRedacoes = validatedRedacoes;
                hideLoading();

                if (currentFetchedRedacoes.length > 0) {
                    const activeCount = currentFetchedRedacoes.filter(r => !r._expired).length;
                    const expiredCount = currentFetchedRedacoes.filter(r => r._expired).length;
