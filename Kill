        function removeUrls(text) { 
            return text.replace(/(https?:\/\/[^\s]+)|(www\.[^\s]+)|([a-zA-Z0-9-]+\.[a-zA-Z0-9-.]+\/[^\s]*)/g, '').trim(); 
        }

        // CORREÇÃO: Extrair tema específico do enunciado
        function extractTemaFromEnunciado(enunciado) {
            if (!enunciado) return null;
            
            // Padrões comuns de tema em redações ENEM
            const padroes = [
                /sobre\s+o\s+tema\s+["']?([^"']+)["']?/i,
                /tema\s*:?\s*["']?([^"']+)["']?/i,
                /sobre\s+["']?([^"']+)["']?/i,
                /tema\s+obrigat[óo]rio\s*:?\s*["']?([^"']+)["']?/i
            ];
            
            for (const padrao of padroes) {
                const match = enunciado.match(padrao);
                if (match && match[1]) {
                    return match[1].trim();
                }
            }
            
            // Se não encontrou padrão específico, tenta extrair do enunciado completo
            // removendo instruções genéricas
            const linhas = enunciado.split('\n').filter(l => l.trim());
            for (const linha of linhas) {
                const limpa = linha.trim();
                // Ignora linhas que são instruções genéricas
                if (!limpa.match(/^(com base|a partir|redija|apresentando|selecione|organize|relembre|critérios)/i) &&
                    limpa.length > 20 && limpa.length < 200) {
                    return limpa;
                }
            }
            
            return null;
        }

        function parseRedactionSections(rawHtmlContent) { 
            const sections = { 
                'ENUNCIADO': { content: '', isImage: false, tema: null }, 
                'Texto I': { content: '', isImage: false }, 
                'Texto II': { content: '', isImage: false }, 
                'Texto III': { content: '', isImage: false } 
            }; 

            const doc = new DOMParser().parseFromString(rawHtmlContent, 'text/html'); 
            const body = doc.body; 
            let currentSectionKey = null; 
            let tempContentNodes = []; 

            const flushContent = () => { 
                if (currentSectionKey && tempContentNodes.length > 0) { 
                    const sectionHtml = tempContentNodes.map(node => node.outerHTML || node.textContent).join(''); 
                    sections[currentSectionKey].isImage = sectionHtml.includes('<img'); 
                    const textoLimpo = sections[currentSectionKey].isImage ? '[IMAGEM]' : removeUrls(stripHtml(sectionHtml)).trim();
                    sections[currentSectionKey].content = textoLimpo;
                    
                    // Se for enunciado, tenta extrair o tema
                    if (currentSectionKey === 'ENUNCIADO' && textoLimpo) {
                        sections[currentSectionKey].tema = extractTemaFromEnunciado(textoLimpo);
                    }
                } 
                tempContentNodes = []; 
            }; 

            for (let node of body.childNodes) { 
                let isSectionHeader = false; 
                if (node.nodeType === Node.ELEMENT_NODE) { 
                    for (const identifier of Object.keys(sections)) { 
                        const strongElement = node.tagName === 'STRONG' ? node : node.querySelector('strong'); 
                        if (strongElement && strongElement.textContent.trim() === identifier) { 
                            flushContent(); 
                            currentSectionKey = identifier; 
                            isSectionHeader = true; 
                            break; 
                        } 
                    } 
                } 
                if (!isSectionHeader && currentSectionKey) tempContentNodes.push(node); 
            } 

            flushContent(); 
            return sections; 
        }

        async function fetchGeminiContent(prompt) { 
            const response = await fetch(getProxyUrl('/generate'), { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ prompt }) 
            }); 

            if (!response.ok) { 
                const errorData = await response.json().catch(() => ({}));
                throw new Error(`Erro Proxy Gemini: ${response.status} - ${JSON.stringify(errorData)}`); 
            } 

            const result = await response.json(); 
            if (result.error) throw new Error(result.error);
            return result.text || ''; 
        }

        // CORREÇÃO: Função para garantir que o tema está no prompt
        async function callGeminiAPI(redactionContent, temaEspecifico, totalSteps, currentStep) {
            updateProgress(currentStep, totalSteps, 'Gerando texto com IA...'); 

            // Se não encontrou tema específico, usa o título da redação
            const temaFinal = temaEspecifico || redactionContent.match(/Título da Redação:\s*([^\n]+)/)?.[1] || 'o tema proposto';
            
            const promptGeracao = promptsGeracao[Math.floor(Math.random() * promptsGeracao.length)]
                .replace(/{temaRedacao}/g, temaFinal)
                .replace('{dadosRedacao}', redactionContent);

            const rawResponse = await fetchGeminiContent(promptGeracao); 

            if (!rawResponse.includes("TITULO:") || !rawResponse.includes("TEXTO:")) {
                throw new Error('Resposta da API Gemini inválida.');
            }

            // Extrair título e texto
            let generatedTitle = '';
            let generatedText = '';
            
            const tituloMatch = rawResponse.match(/TITULO:\s*([^\n]+)(?:\n|$)/i);
            const textoMatch = rawResponse.match(/TEXTO:\s*([\s\S]+)$/i);
            
            if (tituloMatch) generatedTitle = tituloMatch[1].trim();
            if (textoMatch) generatedText = textoMatch[1].trim();
            
            // Fallback se regex falhar
            if (!generatedTitle) {
                generatedTitle = rawResponse.split("TITULO:")[1].split("TEXTO:")[0].replace(/^Título:\s*/i, '').replace(/#/g, '').trim();
            }
            if (!generatedText) {
                generatedText = rawResponse.split("TEXTO:")[1].trim();
            }

            // Verificar se o texto gerado realmente trata do tema
            // Verificação interna de aderência ao tema (sem log)
            const textoLower = generatedText.toLowerCase();
            const temaLower = temaFinal.toLowerCase();
            const palavrasTema = temaLower.split(/\s+/).filter(p => p.length > 3);
            const palavrasEncontradas = palavrasTema.filter(p => textoLower.includes(p));
            if (palavrasEncontradas.length < Math.max(1, palavrasTema.length * 0.3)) {
                // tema pode não estar bem representado, mas continua
            }

            updateProgress(currentStep + 1, totalSteps, 'Humanizando texto...'); 

            const promptHumanizacao = promptsHumanizacao[Math.floor(Math.random() * promptsHumanizacao.length)]
                .replace('{textoRedacao}', generatedText);

            const humanizedText = await fetchGeminiContent(promptHumanizacao); 

            if (!humanizedText) throw new Error('Humanização retornou texto vazio.');

            return { title: generatedTitle, text: humanizedText, tema: temaFinal };
        }

