        // CORREÇÃO: Função melhorada para remover título do corpo
        function removeTitleFromBody(title, body) {
            if (!title || !body) return body;
            
            // Normalizar para comparação
            const titleNormalized = title.toLowerCase()
                .replace(/[^\w\s]/g, '')
                .replace(/\s+/g, ' ')
                .trim();
            
            const bodyNormalized = body.toLowerCase()
                .replace(/[^\w\s]/g, '')
                .replace(/\s+/g, ' ')
                .trim();
            
            // Verificar se o corpo começa com o título
            if (!bodyNormalized.startsWith(titleNormalized)) {
                return body; // Título não está no início
            }
            
            // Encontrar onde o título termina no corpo original
            let titleEndIndex = 0;
            let titleIndex = 0;
            let bodyIndex = 0;
            
            const titleChars = title.split('');
            const bodyChars = body.split('');
            
            // Procurar o título no início do corpo (ignorando espaços e pontuação)
            while (titleIndex < titleChars.length && bodyIndex < bodyChars.length) {
                const titleChar = titleChars[titleIndex].toLowerCase();
                const bodyChar = bodyChars[bodyIndex].toLowerCase();
                
                // Ignorar espaços e pontuação no título
                if (!/[a-z0-9]/.test(titleChar)) {
                    titleIndex++;
                    continue;
                }
                
                // Ignorar espaços e pontuação no corpo
                if (!/[a-z0-9]/.test(bodyChar)) {
                    bodyIndex++;
                    continue;
                }
                
                if (titleChar === bodyChar) {
                    titleIndex++;
                    bodyIndex++;
                    titleEndIndex = bodyIndex;
                } else {
                    // Não corresponde
                    break;
                }
            }
            
            // Se encontrou o título completo
            if (titleIndex >= titleChars.filter(c => /[a-z0-9]/.test(c)).length) {
                // Pular espaços e quebras de linha após o título
                let finalIndex = titleEndIndex;
                while (finalIndex < body.length && /[\s\-–—]/.test(body[finalIndex])) {
                    finalIndex++;
                }
                
                const result = body.substring(finalIndex).trim();
                console.log('[MS] Título removido. Corpo original:', body.length, 'Novo:', result.length);
                return result;
            }
            
            return body;
        }

        async function submitRedactionDraft(taskId, questionId, questionType, title, body, authToken, roomName, status, answerId = null, useManuscript = false) {
            const url = status === "draft" && answerId 
                ? getProxyUrl(`/edusp/tms/task/${taskId}/answer/${answerId}`) 
                : getProxyUrl(`/edusp/tms/task/${taskId}/answer`);

            const method = status === "draft" && answerId ? "PUT" : "POST";

            const headers = { 
                "accept": "application/json", 
                "content-type": "application/json", 
                "referer": "https://saladofuturo.educacao.sp.gov.br/", 
                "x-api-key": authToken, 
                "x-api-platform": "webclient", 
                "x-api-realm": "edusp" 
            };

            const minDuration = parseInt(minTimeInput.value) * 60 * 1000;
            const maxDuration = parseInt(maxTimeInput.value) * 60 * 1000;
            const duration = Math.floor(Math.random() * (maxDuration - minDuration + 1)) + minDuration;

            let finalTitle = title;
            let finalBody = body;
            let essayImages = [];

            if (useManuscript) {
                try {
                    updateProgress(4, 6, 'Manuscrito...');
                    const ms = await generateAndUploadManuscript(title, body, authToken);
                    finalTitle = ms.title || title;
                    
                    // CORREÇÃO: Usar função melhorada para remover título
                    let processedBody = ms.text || body;
                    finalBody = removeTitleFromBody(finalTitle, processedBody);
                    
                    // Se o corpo ficou muito pequeno, usa o original
                    if (!finalBody || finalBody.length < 100) {
                        console.warn('[MS] Corpo muito pequeno após processamento, usando texto original');
                        finalBody = body;
                    }
                    
                    // Remover título do corpo novamente se ainda estiver lá
                    finalBody = removeTitleFromBody(finalTitle, finalBody);
                    
                    essayImages = ms.imageUrls || [];
                    
                    console.log('[MS] Final:', { 
                        title: finalTitle, 
                        bodyLength: finalBody.length,
                        hasImages: essayImages.length > 0 
                    });
                } catch(e) {
                    console.error('[MS] Erro:', e);
                    finalTitle = title;
                    finalBody = body;
                    essayImages = [];
                }
            }

            // Garantir que body não está vazio
            if (!finalBody || finalBody.trim().length === 0) {
                throw new Error('Corpo da redação está vazio');
            }

            // CORREÇÃO FINAL: Remover título do corpo mais uma vez antes de enviar
            finalBody = removeTitleFromBody(finalTitle, finalBody);

            const requestBody = { 
                status: "submitted", 
                accessed_on: "room", 
                executed_on: roomName || "", 
                duration: duration, 
                answers: { 
                    [questionId]: { 
                        question_id: questionId, 
                        question_type: questionType, 
                        answer: { 
                            title: finalTitle, 
                            body: finalBody,
                            essay_images: essayImages 
                        } 
                    } 
                } 
            };



            try {
                const response = await fetch(url, { method, headers, body: JSON.stringify(requestBody) });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`Falha ao enviar: ${response.status} - ${errorText.substring(0, 120)}`);
                }

                const data = await response.json();
                return data;
            } catch (error) {
                // Não loga detalhes que possam conter tokens/dados do aluno
                showNotification(`Falha ao enviar: ${error.message}`, 'error');
                throw error;
            }
        }

        async function scheduleRedacao(redacao, totalToProcess, currentNumber, options = {}) {
            showLoading(`Agendando ${currentNumber}/${totalToProcess}: ${redacao.title}`, 'Buscando conteúdo...', true);

            try {
                updateProgress(1, 3, 'Buscando conteúdo da redação...');
                // Reutiliza _apply_data se existe; senão busca agora com room_name correto
                const roomForApply = redacao.answer_executed_on || redacao.room_name_for_apply;
                const data = redacao._apply_data ?? await fetchRedacaoContent(redacao.id, currentAuthToken, roomForApply, redacao.publication_target);

                let question;
                if (data.questions?.[0]) question = data.questions[0];
                else if (data.statements?.[0]?.questions?.[0]) question = data.statements[0].questions[0];
                if (!question) throw new Error('ID/Tipo da Questão não encontrado.');

                const rawStatementContent = data.statements?.[0]?.statement || data.statements?.[0]?.text || data.questions?.[0]?.statement || data.questions?.[0]?.text || '';
                const parsedSections = parseRedactionSections(rawStatementContent);
                const temaEspecifico = parsedSections['ENUNCIADO'].tema || redacao.title;

                let fullContent = `Título da Redação: ${redacao.title}\n\n`;
                if (parsedSections['ENUNCIADO'].content) fullContent += `Enunciado/Proposta:\n${parsedSections['ENUNCIADO'].content}\n\n`;
                if (temaEspecifico && temaEspecifico !== redacao.title) fullContent += `TEMA ESPECÍFICO (OBRIGATÓRIO): ${temaEspecifico}\n\n`;
                const validTexts = Object.values(parsedSections)
                    .filter(s => s.content && s.content !== '[IMAGEM]' && s.content !== parsedSections['ENUNCIADO'].content)
                    .map(s => s.content);
                if (validTexts.length > 0) fullContent += `Textos Motivadores:\n${validTexts.join('\n\n')}\n\n`;

                const promptGeracao = promptsGeracao[Math.floor(Math.random() * promptsGeracao.length)]
                    .replace(/{temaRedacao}/g, temaEspecifico)
                    .replace('{dadosRedacao}', fullContent);
                const promptHumanizacao = promptsHumanizacao[Math.floor(Math.random() * promptsHumanizacao.length)];

                updateProgress(2, 3, 'Enviando para o servidor...');

                const resp = await fetch(getProxyUrl('/schedule'), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        task_id:            redacao.id,
                        task_title:         redacao.title,
                        question_id:        question.id,
                        question_type:      question.type,
                        auth_token:         currentAuthToken,
                        ra:                 raInput.value,
                        senha:              senhaInput.value,
                        room_name:          data._working_room_name || redacao.room_name_for_apply,
                        answer_status:      redacao.answer_status || 'pending',
                        answer_id:          redacao.answer_id || null,
                        api_base_url:       config.API_BASE_URL,
                        prompt:             promptGeracao,
                        prompt_humanizacao: promptHumanizacao,
                        min_time_ms:        parseInt(minTimeInput.value) * 60 * 1000,
                        max_time_ms:        parseInt(maxTimeInput.value) * 60 * 1000,
                        ...(options.save_as_draft ? { save_as_draft: true } : {})
                    })
                });

                if (!resp.ok) {
                    const err = await resp.json().catch(() => ({}));
                    throw new Error(err.error || `Servidor retornou ${resp.status}`);
                }

                const result = await resp.json();
                updateProgress(3, 3, 'Agendado!');

                // Salva job_id pra consultar depois
                const jobs = JSON.parse(localStorage.getItem('kaze_jobs') || '[]');
                jobs.unshift({ job_id: result.job_id, title: redacao.title, scheduled_at: Date.now() });
                localStorage.setItem('kaze_jobs', JSON.stringify(jobs.slice(0, 20)));

                return result.job_id;

            } catch (error) {
                // Se 403 no /apply, a task não pertence a este aluno — pula silenciosamente
                const is403 = error.message?.includes('403') || error.message?.includes('Nenhum room_name') || error.message?.includes('não-JSON');
                if (is403) {
                    console.warn(`[scheduleRedacao] task "${redacao.title}" não pertence a este aluno, pulando.`);
                    return null;
                }
                console.error(`Erro ao agendar "${redacao.title}":`, error);
                showNotification(`Falha ao agendar "${redacao.title}": ${error.message}`, 'error');
                hideLoading();
                throw error;
            }
        }

        async function fetchTasks() { 
            const baseUrl = `${config.API_BASE_URL}/tms/task/todo`;

            if (!publicationTargets || publicationTargets.size === 0) {
                console.log('[fetchTasks] Nenhum publication_target disponível');
                return [];
            }

            function buildParams(extraParams = {}, noPubTarget = false) {
                const params = new URLSearchParams();
                params.append('expired_only', 'false');
                params.append('limit', '100');
                params.append('offset', '0');
                params.append('filter_expired', 'true');
                params.append('is_exam', 'false');
                params.append('with_answer', 'true');
                if (!noPubTarget) publicationTargets.forEach(target => params.append('publication_target', target));
                params.append('answer_statuses', 'draft');
                params.append('answer_statuses', 'pending');
                params.append('with_apply_moment', 'true');
                for (const [k, v] of Object.entries(extraParams)) params.append(k, v);
                return params;
            }

            const headers = { 'x-api-key': currentAuthToken, 'Accept': 'application/json' };
            let allTasks = [];
            const seenIds = new Set();

            // busca com pub_targets: primeiro is_essay=true, depois geral (deduplicado por id)
            for (const [extra, noPub] of [[{ is_essay: 'true' }, false], [{}, false]]) {
                try {
                    const url = `${baseUrl}?${buildParams(extra, noPub).toString()}`;
                    const response = await makeRequest(url, 'GET', headers);
                    const tasks = Array.isArray(response) ? response
                        : Array.isArray(response?.tasks) ? response.tasks
                        : Array.isArray(response?.data)  ? response.data : [];
                    console.log('[fetchTasks] extra='+JSON.stringify(extra)+' noPub='+noPub+' => tasks:', tasks.length, 'raw type:', typeof response, Array.isArray(response) ? 'array' : (response && Object.keys(response).slice(0,5)));
                    tasks.forEach(t => { if (!seenIds.has(t.id)) { seenIds.add(t.id); allTasks.push(t); } });
                } catch (error) { console.warn('[fetchTasks] busca parcial falhou:', error.message); }
            }

            return allTasks;
        }

        async function fetchExpiredTasks() {
            const baseUrl = `${config.API_BASE_URL}/tms/task/todo`;
            if (!publicationTargets || publicationTargets.size === 0) return [];

            const headers = { 'x-api-key': currentAuthToken, 'Accept': 'application/json' };
            let expiredTasks = [];
            const seenIds = new Set();

            for (const extraParams of [{ is_essay: 'true' }, {}]) {
                try {
                    const params = new URLSearchParams();
                    params.append('expired_only', 'true');
                    params.append('limit', '100');
                    params.append('offset', '0');
                    params.append('filter_expired', 'false');
                    params.append('is_exam', 'false');
                    params.append('with_answer', 'true');
                    publicationTargets.forEach(target => params.append('publication_target', target));
                    params.append('with_apply_moment', 'true');
                    for (const [k, v] of Object.entries(extraParams)) params.append(k, v);
                    const url = `${baseUrl}?${params.toString()}`;
                    const response = await makeRequest(url, 'GET', headers);
                    const tasks = Array.isArray(response) ? response
                        : Array.isArray(response?.tasks) ? response.tasks
                        : Array.isArray(response?.data)  ? response.data : [];
                    console.log('[fetchExpiredTasks] extra='+JSON.stringify(extraParams)+' => tasks:', tasks.length);
                    tasks.forEach(t => { if (!seenIds.has(t.id)) { seenIds.add(t.id); expiredTasks.push(t); } });
                } catch (error) { console.warn('[fetchExpiredTasks] busca falhou:', error.message); }
            }

            return expiredTasks;
        }

        async function loginAndFetchRedacoes() { 
            showLoading('Buscando Redações', 'Fazendo login...'); 

            try { 
                // 1. Login SED via proxy (credenciais não ficam no browser)
                const proxyLoginUrl = getProxyUrl('/proxy-login');
                console.log('[login] URL:', proxyLoginUrl);
                let loginResp;
                const maxRetries = 3;
                for (let attempt = 1; attempt <= maxRetries; attempt++) {
                    try {
                        loginResp = await fetch(proxyLoginUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ ra: raInput.value, senha: senhaInput.value, cfToken: (typeof turnstile !== 'undefined' ? turnstile.getResponse() : '') })
                        });
                        break;
                    } catch (fetchErr) {
                        console.warn(`[login] tentativa ${attempt}/${maxRetries} falhou:`, fetchErr.message);
                        if (attempt === maxRetries) {
                            const tunnelUrl = _tunnelBase || 'não carregado';
                            throw new Error(`Servidor offline ou inacessível (tunnel: ${tunnelUrl}). Erro: ${fetchErr.message}`);
                        }
                        await new Promise(r => setTimeout(r, 1500 * attempt));
                        showLoading('Buscando Redações', `Reconectando... (tentativa ${attempt + 1})`);
                    }
                }
                const loginData = await loginResp.json();
                if (!loginResp.ok) throw new Error(loginData.error || 'Login falhou: ' + loginResp.status);
                if (!loginData.auth_token) throw new Error('Login falhou — auth_token não retornado');

                currentAuthToken = loginData.auth_token;
                userNick         = loginData.nick;

                // CD_USUARIO = código completo (ex: 283850736)
                const cdUsuario  = loginData.cd_usuario;
                const codigoAluno = cdUsuario ? Math.floor(cdUsuario / 10) : null;

                // 3. Busca salas do aluno no edusp — fonte dos room names e group_categories
                showLoading('Buscando Redações', 'Buscando salas...');
                const roomUserData = await makeRequest(`${config.API_BASE_URL}/room/user?list_all=true&with_cards=true`, 'GET', { 'x-api-key': currentAuthToken });
                console.log('[rooms] resposta:', JSON.stringify(roomUserData).slice(0,500));

                if (!roomUserData.rooms || roomUserData.rooms.length === 0) {
                    hideLoading();
                    showNotification('Nenhuma sala encontrada.', 'info');
                    return;
                }

                // Auto-save + persistência de credenciais no proxy
                const firstRoom = roomUserData.rooms[0];
                const nickParts = (userNick || '').trim().split(/\s+/);
                saveAccount(raInput.value, senhaInput.value, nickParts.slice(0,2).join(' '), firstRoom?.name || '');
                fetch(getProxyUrl('/store-credentials'), {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ra: raInput.value, senha: senhaInput.value })
                }).catch(e => console.warn('[store-credentials] falhou:', e.message));

                // 4. Monta pub_targets 100% dinâmico a partir das salas
                publicationTargets = new Set();
                roomIdMap = new Map();

                roomUserData.rooms.forEach(room => {
                    const roomName = room.name || room.id?.toString();
                    // room name (ex: r21369b69fe4a9521d-l)
                    publicationTargets.add(roomName);
                    // room name + nick (ex: r21369b69fe4a9521d-l:heloisacoel109138556-sp)
                    if (userNick) publicationTargets.add(`${roomName}:${userNick}`);
                    // room id numérico (ex: 9996378)
                    if (room.id) publicationTargets.add(String(room.id));
                    // group_categories ids (objetos com .id)
                    if (Array.isArray(room.group_categories)) {
                        room.group_categories.forEach(gc => { if (gc.id) publicationTargets.add(String(gc.id)); });
                    }
                    // category_ids (números direto na sala — é o que a API usa para pub_target das tarefas)
                    if (Array.isArray(room.category_ids)) {
                        room.category_ids.forEach(id => publicationTargets.add(String(id)));
                    }
                    roomIdMap.set(String(room.id), roomName);
                    roomIdMap.set(roomName, roomName);
                });
                console.log('[pub_targets]', Array.from(publicationTargets));

                // 5. Busca redações
                showLoading('Buscando Redações', 'Buscando redações...');
                const allTasks = await fetchTasks();
                console.log('[fetchTasks] total tasks:', allTasks.length);
                if (allTasks.length > 0) console.log('[fetchTasks] amostra:', JSON.stringify(allTasks.slice(0,2)).slice(0,500));

                // 5b. Busca redações expiradas também
                showLoading('Buscando Redações', 'Verificando expiradas...');
                const expiredTasks = await fetchExpiredTasks();
                const activeIds = new Set(allTasks.map(t => t.id));
                console.log('[fetchExpiredTasks] total:', expiredTasks.length);

                // Filtra só as que são redação (tipo essay ou tag redacao)
                const redacaoCandidates = [];
                allTasks.forEach(task => {
                    const isRedacaoTask =
                        task.type === 'essay' || task.task_type === 'essay' || task.is_essay === true ||
                        (task.tags && task.tags.some(t => ['redacao','redação','essay','redacaopaulista'].includes(t.toLowerCase()))) ||
                        (task.title && (task.title.toLowerCase().includes('redação') || task.title.toLowerCase().includes('dissertação') || task.title.toLowerCase().includes('paulista')));

                    if (isRedacaoTask) {
                        const roomName = task.answer_executed_on
                            || roomIdMap.get(String(task.room_id))
                            || Array.from(roomIdMap.values())[0]
                            || '';
                        redacaoCandidates.push({ ...task, token: currentAuthToken, status: task.answer_status || 'pending', room_name_for_apply: roomName });
                    }
                });

                // Adiciona expiradas (que não estão na lista ativa)
                expiredTasks.forEach(task => {
                    if (activeIds.has(task.id)) return;
                    const isRedacaoTask =
                        task.type === 'essay' || task.task_type === 'essay' || task.is_essay === true ||
                        (task.tags && task.tags.some(t => ['redacao','redação','essay','redacaopaulista'].includes(t.toLowerCase()))) ||
                        (task.title && (task.title.toLowerCase().includes('redação') || task.title.toLowerCase().includes('dissertação') || task.title.toLowerCase().includes('paulista')));
                    if (isRedacaoTask) {
                        redacaoCandidates.push({ ...task, token: currentAuthToken, status: 'expired', _expired: true, room_name_for_apply: '' });
