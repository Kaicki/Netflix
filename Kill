        async function fetchRedacaoContent(taskId, token, roomName, taskPublicationTarget) {
            // Usa o proxy cloudflare (gemini_proxy.py /apply) que envia headers corretos pra API.
            // O proxy retorna JSON sempre:
            //   - 200 + dados = sucesso
            //   - 403 + {error:"403"} = API negou (task não é deste aluno) → skip
            //   - 5xx / HTML = problema no tunnel/Cloudflare → throw (não descartar a task)

            // Prioridade: answer_executed_on → pub_target da task → rooms do aluno → sem room_name
            const candidates = [...new Set([
                roomName,                        // answer_executed_on se existir
                taskPublicationTarget,           // publication_target da task (ex: "1175")
                null,                            // sem room_name (API tenta resolver pelo token)
                roomName?.split(':')[0],
                ...Array.from(roomIdMap.values()),
                ...Array.from(publicationTargets).map(t => t.split(':')[0]),
                ...Array.from(publicationTargets),
            ])];

            let lastError = null;
            let proxyError = null;

            for (const rn of candidates) {
                try {
                    // Token e RA nunca vão em query params — sempre no body (POST)
                    const applyEndpoint = getProxyUrl('/apply');

                    const applyBody = {
                        task_id:  taskId,
                        token:    token,
                        api_base: config.API_BASE_URL,
                    };
                    if (rn !== null && rn !== undefined) applyBody.room_name = rn;

                    const applyResp = await fetch(applyEndpoint, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(applyBody),
                    });

                    // Quando no Vercel, a edge function sempre retorna JSON ou text/plain com o erro real
                    // Só faz checagem de Cloudflare quando usando tunnel local
                    const ct = applyResp.headers.get('content-type') || '';
                    if (!IS_HOSTED && !ct.includes('application/json')) {
                        const html = await applyResp.text();
                        const isCloudflare = html.includes('Just a moment') || html.includes('Cloudflare') || html.includes('cf-browser-verification');
                        const errMsg = isCloudflare
                            ? 'Tunnel bloqueado — reinicie o cloudflared'
                            : `Proxy retornou HTML inesperado (${applyResp.status})`;
                        console.error(`[apply] ⚠️ ${errMsg}`);
                        proxyError = new Error(errMsg);
                        continue;
                    }

                    let result;
                    try {
                        const rawText = await applyResp.text();
                        result = JSON.parse(rawText);
                    } catch(e) {
                        lastError = new Error(`Resposta inválida (${applyResp.status})`);
                        continue;
                    }

                    if (applyResp.status === 403 || result?._status === 403 || result?.error === '403') {
                        lastError = new Error(`HTTP 403 - ${result?.detail || result?.error || ''}`);
                        continue;
                    }

                    if (!applyResp.ok) {
                        throw new Error(`HTTP ${applyResp.status} - ${result?.detail || result?.error || ''}`);
                    }

                    if (result && typeof result === 'object') result._working_room_name = rn ?? '';
                    return result;

                } catch (e) {
                    if (e.message?.includes('403')) {
                        lastError = e;
                        continue;
                    }
                    proxyError = e;
                    continue;
                }
            }

            // Erro de infra (Cloudflare/rede) sempre tem prioridade — não descartar a task por isso
            if (proxyError) throw proxyError;
            // Se teve 403 em todos os room_names = task realmente não pertence ao aluno
            throw lastError || new Error('Nenhum room_name funcionou para task ' + taskId);
        }

        function stripHtml(htmlString) { 
            return new DOMParser().parseFromString(htmlString, 'text/html').body.textContent || ""; 
