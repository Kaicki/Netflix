        async function makeRequest(url, method = 'GET', headers = {}, body = null) {
            // Roteia chamadas edusp-api e SED pelo proxy (resolve CORS + CF challenge)
            if (url.includes('edusp-api.ip.tv')) {
                const parsed = new URL(url);
                url = getProxyUrl('/edusp' + parsed.pathname) + parsed.search;
            }
            if (IS_HOSTED && url.includes('sedintegracoes.educacao.sp.gov.br')) {
                const parsed = new URL(url);
                url = getProxyUrl('/sed/' + parsed.pathname.replace(/^\//, '')) + parsed.search;
            }

            const options = { 
                method, 
                headers: { ...getDefaultHeaders(), ...headers } 
            }; 
            if (body) options.body = JSON.stringify(body); 

            let response;
            for (let _retry = 0; _retry < 2; _retry++) {
                try {
                    response = await fetch(url, options);
                    break;
                } catch (fetchErr) {
                    if (_retry === 0 && url.includes('trycloudflare.com')) {
                        console.warn('[makeRequest] retry após falha:', fetchErr.message);
                        await new Promise(r => setTimeout(r, 2000));
                        continue;
                    }
                    throw new Error(`Rede: ${fetchErr.message} (URL: ${url.split('?')[0]})`);
                }
            }

            if (!response.ok) { 
                const errorText = await response.text().catch(() => 'Unknown error');
                throw new Error(`HTTP ${method} ${url.split('?')[0]} => ${response.status} - ${errorText.substring(0, 200)}`); 
            } 

            return response.json(); 
        }

        function isRedacao(task) { 
