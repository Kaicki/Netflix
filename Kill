  async function fetchTunnelAndMaint() {
    const sources = [
      '/tunnel.json?_='+Date.now(),
      '/api/tunnel?_='+Date.now()
    ];
    for (const src of sources) {
      try {
        const r = await fetch(src);
        if (!r.ok) continue;
        let t = await r.json();

        if (!t || !t.url) continue;
        const mr = await Promise.race([
          fetch(t.url+'/api/admin/maintenance').then(function(r){return r.ok?r.json():null;}),
          new Promise(function(_,rej){setTimeout(function(){rej(new Error('timeout'));},5000)})
        ]);
        showMaint(mr && mr.maintenance && mr.maintenance.kazereda);
        return;
      } catch(_) {}
    }
  }
  fetchTunnelAndMaint();
